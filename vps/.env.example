# Copie para .env e ajuste os valores

# API key do WAHA (usada pelo Lovable pra enviar mensagens)
# Gere com: openssl rand -hex 24
WAHA_API_KEY=troque-por-uma-chave-forte

# Login do dashboard http://IP:3001
WAHA_DASHBOARD_USER=admin
WAHA_DASHBOARD_PASS=troque-por-senha-forte

# Webhook do Lovable (edge function aura-webhook)
# Pegue o valor do AURA_WEBHOOK_SECRET no painel Lovable > Secrets
WEBHOOK_URL=https://okizljseegzvhdpywzpr.supabase.co/functions/v1/aura-webhook?secret=COLE_AQUI_O_AURA_WEBHOOK_SECRET
